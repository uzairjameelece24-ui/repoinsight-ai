# RepoInsight AI — Environment Variables
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Your Groq API key. Obtain from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Optional (shown with defaults) ───────────────────────────────────────────
# Directory where ChromaDB will persist vector data to disk.
# CHROMA_DB_DIR=./chroma_data

# Directory where cloned Git repositories are stored.
# REPOS_STORAGE_DIR=./cloned_repos

# Local embedding model (SentenceTransformers). all-MiniLM-L6-v2 is fast and accurate.
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Groq chat model for answer generation.
# Options: llama-3.1-8b-instant (faster), llama-3.3-70b-specdec (higher quality), mixtral-8x7b-32768
# CHAT_MODEL=llama-3.1-8b-instant

# Maximum characters per code chunk (default: 800)
# MAX_CHUNK_SIZE=800

# Character overlap between consecutive chunks (default: 100)
# CHUNK_OVERLAP=100

# Number of top-k results retrieved from ChromaDB per query (default: 4)
# TOP_K_RESULTS=4

# ChromaDB batch upload size (default: 100)
# BATCH_SIZE=100
